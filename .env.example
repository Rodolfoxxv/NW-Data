# Exemplo de .env para NW-Data

# Caminho relativo do arquivo DuckDB (ex: data/database.duckdb)
DUCKDB_PATH=data/database.duckdb
# Caminho base onde o DuckDB está localizado (pasta que contém DUCKDB_PATH)
DESTINATION_PATH=.

# Diretório de saída dos CSV gerados pelo Extract
CSV_OUTPUT_DIR=./ETL/csv_output
# Caminho do arquivo SQL fonte para o extract
SQL_SOURCE_PATH=./data/northwind-data.sql

# Supabase / PostgreSQL (para scripts de migração)
SUPABASE_URL=
SUPABASE_KEY=
DB_HOST=
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_PORT=5432

# Outros controle
TRUNCATE_BEFORE_LOAD=false
